# ─── Server Configuration ───────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────
# In production, set this to your frontend domain:
# CLIENT_URL=https://yourportfolio.vercel.app
CLIENT_URL=http://localhost:3000

# ─── Email Configuration (Nodemailer) ───────────────────
# OPTION 1 — Gmail (recommended for personal portfolios)
# Enable "App Passwords" in your Google Account for security
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Recipient email — where contact form messages are sent
EMAIL_TO=your_email@gmail.com

# ─── Rate Limiting ───────────────────────────────────────
# Max requests per window (per IP)
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=10              # max 10 requests per 15 min
